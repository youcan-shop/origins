{% comment %}
  Renders an order summary item

  Accepts:
  - product: {Object} Product information

  Usage:
  {% render 'order-summary-item', product: {...} %}
{% endcomment %}

<div class="item">
  <div class="image">
    {% if product.image %}
      <img
        loading="lazy"
        height="100%"
        width="100%"
        src="{{ product.image }}"
        alt="{{ product.name }}"
      >
    {% else %}
      <div class="card-placeholder">
        {% render 'yc-placeholder', name: 'product', size: '32' %}
      </div>
    {% endif %}
  </div>
  <div class="info">
    <div class="heading">
      <span class="name" title="{{ product.name }}">
        {{ product.name | default: 'Product Name' }}
      </span>
      {% if product.variations.size > 1 %}
        <p class="variant">
          {% for variant in product.variations %}
            <span>{{- variant[1] -}}</span>
            {% unless forloop.index == product.variations.size - 1 %}
              <span>/</span>
            {% endunless %}
          {% endfor %}
        </p>
      {% endif %}
      {% if product.price %}
        <span class="quantity">x{{ product.quantity }}</span>
      {% endif %}
    </div>
  </div>

  {% if product.price %}
    <span class="item-subtotal">
      {{ product.price | default: 0 | money }}
    </span>
  {% else %}
    <span class="yc-badge item-free" data-status="success">
      {% render 'yc-icon', name: 'gift' %}
      {{ 'order.free' | t }}
    </span>
  {% endif %}
</div>
