{{ 'header-cart-drawer.css' | asset_url | stylesheet_tag }}

{% comment %}
  Renders the header cart drawer

  Usage:
  {% render 'header-cart-drawer' %}
{% endcomment %}

{% assign cart_size = cart.count %}

<yc-drawer id="cart" data-hidden="true" data-direction="rtl">
  <template data-cart-item-template>
    {% render 'cart-drawer-item' %}
  </template>

  <template data-cart-drawer="bundle-group">
    <div class="bundle-group">
      <div class="top">
        <span class="title" data-bundle="title"></span>
        <yc-cart-remove-button data-cart-item="delete-button">
          <button
            class="icon"
            data-delete
            data-size="sm"
            aria-label="Delete"
          >
            {% render 'yc-icon', name: 'trash' %}
          </button>
        </yc-cart-remove-button>
      </div>
      <div class="list" data-bundle="group"></div>
    </div>
  </template>

  <template data-cart-drawer="bundle-item">
    {% render 'cart-drawer-bundle-item' %}
  </template>

  <yc-cart-bubble>
    <button class="cart-btn icon" aria-label="cart" data-toggle>
      <span
        class="total-items"
        data-cart-badge
        {% unless cart_size > 0 %}
          hidden
        {% endunless %}
      >
        {{- cart_size -}}
      </span>
      {% render 'yc-icon', name: 'cart' %}
      <span class="total-amount" data-total>{{ cart.sub_total | default: 0 | money }}</span>
    </button>
  </yc-cart-bubble>
  <div class="drawer-container">
    <div class="drawer-box">
      <div
        class="cart-drawer"
        {% unless cart_size > 0 %}
          data-is-empty
        {% endunless %}

        data-cart
      >
        <div class="header">
          <div class="title">
            {% render 'yc-icon' | name: 'cart' %}
            <span>{{ 'cart.drawer.title' | t }}</span>
          </div>
          <button class="close-btn icon" data-size="sm" aria-label="close" data-toggle>
            {% render 'yc-icon' | name: 'x-mark' %}
          </button>
        </div>
        <yc-cart-drawer-items>
          {% for item in cart.items %}
            {% render 'cart-drawer-item', product: item %}
          {% endfor %}

          {% if cart.bundles %}
            {% assign types = 'single,multi,buyxgety' | split: ',' %}

            {% for t in types %}
              {% assign type = cart.bundles[t] %}

              {% for bundle in type %}
                <div class="bundle-group">
                  <div class="top">
                    <span class="title" data-bundle="title">{{ bundle.title }}</span>
                    <yc-cart-remove-button
                      item="{% for bundle_item in bundle.items %} {{ bundle_item.id }} {% unless forloop.index == bundle.items.size %} , {% endunless %} {% endfor %}"
                      product-variant="{% for bundle_item in bundle.items %} {{ bundle_item.product_variant_id }} {% unless forloop.index == bundle.items.size %} , {% endunless %} {% endfor %}"
                      data-cart-item="delete-button"
                    >
                      <button
                        class="icon"
                        data-delete
                        data-size="sm"
                        aria-label="Delete"
                      >
                        {% render 'yc-icon', name: 'trash' %}
                      </button>
                    </yc-cart-remove-button>
                  </div>
                  <div class="list" data-bundle="group">
                    {% for bundle_item in bundle.items %}
                      {% render 'cart-drawer-bundle-item', product: bundle_item %}
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            {% endfor %}
          {% endif %}
        </yc-cart-drawer-items>
        <div class="footer">
          <div class="totals">
            <span>{{ 'cart.drawer.total' | t }}</span>
            <span data-drawer-total>{{ cart.sub_total | default: 0 | money }}</span>
          </div>
          <div class="actions">
            <a href="/cart" class="yc-btn primary">{{ 'cart.drawer.actions.go_to_cart' | t }}</a>
            <button class="yc-btn secondary" data-toggle>
              {{ 'cart.drawer.actions.continue_shopping' | t }}
            </button>
          </div>
        </div>
        {% assign placeholder_title = 'cart.empty.title' | t %}
        {% render 'yc-empty', icon: 'cart', heading: placeholder_title %}
      </div>
    </div>
    <div class="drawer-overlay overlay" data-toggle></div>
  </div>
</yc-drawer>
